# Copy this file to `.env` and fill in real values.
# NEVER put real secrets in THIS file (.env.example is committed to git).
# Put real values only in `.env` (which is git-ignored).

# ----- Database (PostgreSQL — e.g. Supabase Session Pooler) -----
# Use the Session pooler connection string (port 5432) so it works on Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:5432/postgres?sslmode=require"

# ----- Auth (Auth.js) -----
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# ----- Seed admin account (used by `npm run db:seed`) -----
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-this-strong-password"
ADMIN_NAME="Your Name"

# ----- File uploads -----
# Create a PUBLIC Vercel Blob store, then paste its read-write token here.
BLOB_READ_WRITE_TOKEN=""
