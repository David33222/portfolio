# ----- Database -----
# Local dev (SQLite). Leave as-is to run on your machine.
DATABASE_URL="file:./dev.db"
# For Vercel, use a Postgres URL instead and set provider="postgresql" in schema.prisma:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ----- Auth (Auth.js) -----
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# ----- Seed admin account (used by `npm run db:seed`) -----
ADMIN_EMAIL="boluwatifeadeleye383@gmail.com"
ADMIN_PASSWORD="change-this-strong-password"
ADMIN_NAME="David"

# ----- File uploads -----
# Local dev works without this (files save to /public/uploads).
# On Vercel, create a Blob store and paste its token here.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_qOX7XvvfdLErk96i_ewGlkatjC5xa8q68vu8CaSCNeHMynM"
